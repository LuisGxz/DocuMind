# Local dev (docker compose). For prod, point DATABASE_URL at Neon.
DATABASE_URL="postgresql://documind:documind@localhost:5434/documind?schema=public"

# Auth
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# LLM — leave empty to run the deterministic extractive generator (no key, no cost).
# Set to a real key to switch the answer generator to Claude (claude-opus-4-8 / claude-haiku-4-5).
ANTHROPIC_API_KEY=""

# Ingestion limits
MAX_UPLOAD_MB="15"

PORT="3000"
# Comma-separated allowed origins for CORS (frontend dev + prod Pages)
CORS_ORIGINS="http://localhost:4200"
