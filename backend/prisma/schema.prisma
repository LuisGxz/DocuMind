generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  Owner
  Viewer
}

enum DocumentStatus {
  Queued
  Processing
  Indexed
  Failed
}

enum MessageRole {
  user
  assistant
}

model User {
  id               String         @id @default(uuid()) @db.Uuid
  email            String         @unique
  passwordHash     String
  fullName         String
  failedLoginCount Int            @default(0)
  lockoutUntil     DateTime?
  createdAt        DateTime       @default(now())
  refreshTokens    RefreshToken[]
  memberships      Membership[]
  uploads          Document[]     @relation("UploadedBy")
  conversations    Conversation[]
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String    @db.Uuid
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedByHash String?
  createdAt      DateTime  @default(now())

  @@index([userId])
}

model Workspace {
  id            String       @id @default(uuid()) @db.Uuid
  slug          String       @unique
  name          String
  nameEs        String?
  description   String?
  descriptionEs String?
  createdAt     DateTime     @default(now())
  memberships   Membership[]
  documents     Document[]
}

model Membership {
  id          String    @id @default(uuid()) @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String    @db.Uuid
  role        Role
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Document {
  id            String          @id @default(uuid()) @db.Uuid
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId   String          @db.Uuid
  filename      String
  mimeType      String
  sizeBytes     Int
  pageCount     Int             @default(0)
  status        DocumentStatus  @default(Queued)
  statusDetail  String?
  progressPages Int             @default(0)
  chunkCount    Int             @default(0)
  summary       String?
  summaryEs     String?
  uploadedBy    User            @relation("UploadedBy", fields: [uploadedById], references: [id])
  uploadedById  String          @db.Uuid
  createdAt     DateTime        @default(now())
  indexedAt     DateTime?
  chunks        DocumentChunk[]
  conversations Conversation[]

  @@index([workspaceId])
}

model DocumentChunk {
  id         String   @id @default(uuid()) @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String   @db.Uuid
  idx        Int
  page       Int
  content    String
  tokenCount Int
  // pgvector column — written and queried via raw SQL (see RetrievalService / IngestionService).
  embedding  Unsupported("vector(384)")?

  @@index([documentId])
}

model Conversation {
  id         String        @id @default(uuid()) @db.Uuid
  document   Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String        @db.Uuid
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String        @db.Uuid
  title      String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]

  @@index([documentId, userId])
}

model ChatMessage {
  id             String       @id @default(uuid()) @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String       @db.Uuid
  role           MessageRole
  content        String
  citations      Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}
